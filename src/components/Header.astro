---
// src/components/Header.astro
const navLinks = [
  { href: '/', label: 'Home' },
  { 
    href: '/thailand-liveaboards', 
    label: 'Liveaboard',
    subItems: [
      { href: '/thailand-liveaboards/deep-andaman-queen', label: 'Deep Andaman Queen' },
      { href: '/thailand-liveaboards/pawara', label: 'Pawara' },
      { href: '/thailand-liveaboards/sawasdee-fasai', label: 'Sawasdee Fasai' },
      { href: '/thailand-liveaboards/the-junk', label: 'The Junk' },
      { href: '/thailand-liveaboards/thailand-master', label: 'Thailand Master' },
    ]
  },
  { 
    href: '/padi-scuba-diving-courses', 
    label: 'Courses',
    subItems: [
      { href: '/padi-scuba-diving-courses/padi-discover-scuba-diving', label: 'Discover' },
      { href: '/padi-scuba-diving-courses/padi-open-water-diver', label: 'Open Water' },
      { href: '/padi-scuba-diving-courses/padi-advanced-open-water-diver', label: 'Advanced' },
      { href: '/padi-scuba-diving-courses/padi-rescue-diver', label: 'Rescue' },
    ]
  },
  { href: '/day-trip-phuket', label: 'Day Trips' },
  { href: '/liveaboard-itinerary-thailand', label: 'Itinerary' },
  { href: '/dive-sites-thailand', label: 'Dive Sites' },
];
---

<header class="pcom-header">
  <div class="header-container">
    <a href="/" class="header-logo">
      <img src="/images/hero/logo-luna.webp" alt="Luna Diving Thailand" class="logo-image" />
    </a>

    <button id="menuToggle" class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    <nav id="mainNav" class="nav-menu">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class="nav-item">
            <a href={link.href} class="nav-link">
              {link.label}
              {link.subItems && <span class="arrow">▼</span>}
            </a>
            {link.subItems && (
              <ul class="dropdown">
                {link.subItems.map((sub) => (
                  <li><a href={sub.href} class="sub-link">{sub.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const mainNav = document.getElementById('mainNav');

  // Toggle Menu Mobile
  menuToggle?.addEventListener('click', () => {
    const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
    menuToggle.classList.toggle('is-active');
    mainNav?.classList.toggle('is-visible');
    document.body.classList.toggle('menu-open');
  });

  // Mobile: Toggle dropdown al click
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      if (window.innerWidth <= 768 && link.nextElementSibling?.classList.contains('dropdown')) {
        e.preventDefault();
        link.nextElementSibling.classList.toggle('is-visible-mobile');
      }
    });
  });
</script>

<style>
  .pcom-header { position: fixed; top: 0; left: 0; width: 100%; z-index: 9999; background-color: rgba(255, 255, 255, 0.98); border-bottom: 1px solid #f1f1f4; }
  .header-container { max-width: 1200px; margin: 0 auto; padding: 20px 24px; display: flex; justify-content: space-between; align-items: center; }
  
  .header-logo { display: flex; align-items: center; text-decoration: none; }
  .logo-image { width: 140px; height: auto; display: block; }

  .nav-list { list-style: none; padding: 0; margin: 0; display: flex; gap: 24px; }
  .nav-item { position: relative; }
  .nav-link { font-size: 13px; font-weight: 600; text-transform: uppercase; color: #010205; text-decoration: none; display: flex; align-items: center; gap: 4px; }
  .arrow { font-size: 8px; }

  /* Dropdown Desktop */
  @media (min-width: 769px) {
    .dropdown { 
      position: absolute; top: 100%; left: 0; 
      background: #fff; min-width: 200px; padding: 10px 0; 
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); 
      display: none; list-style: none; border: 1px solid #eee;
    }
    .nav-item:hover .dropdown { display: block; }
    .sub-link { display: block; padding: 8px 20px; font-size: 11px; text-transform: uppercase; color: #333; text-decoration: none; }
    .sub-link:hover { color: #008EA7; background: #f9f9f9; }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .menu-toggle { display: flex; flex-direction: column; gap: 6px; cursor: pointer; }
    .hamburger-bar { width: 22px; height: 2px; background: #010205; }
    .nav-menu { position: fixed; top: 0; right: 0; width: 100%; height: 100vh; background: #fff; padding: 100px 40px; transform: translateX(100%); transition: 0.4s; }
    .nav-menu.is-visible { transform: translateX(0); }
    .nav-list { flex-direction: column; gap: 20px; }
    .dropdown { display: none; padding-left: 20px; }
    .dropdown.is-visible-mobile { display: block; }
    .sub-link { padding: 10px 0; display: block; font-size: 16px; color: #666; }
  }
</style>