---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';

interface Props {
  title?: string;
}

const { title = "Luna Diving | Premium Thailand Liveaboards" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <!-- L'Header viene inserito qui e rimarrà fisso in alto su tutte le pagine -->
    <Header />

    <!-- Contenuto dinamico delle singole pagine (Pawara, Thailand Master, ecc.) -->
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  /* Blocca lo scroll della pagina di sfondo quando il menu mobile è aperto */
  body.menu-open {
    overflow: hidden;
  }
</style>