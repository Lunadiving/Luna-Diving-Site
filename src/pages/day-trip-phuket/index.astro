---
// src/pages/day-trip-phuket/index.astro

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';

const quickSpecs = [
  { title: "Duration", value: "1 Day" },
  { title: "Total Dives", value: "3 Ocean Dives" },
  { title: "Departure", value: "Chalong Pier", sub: "Daily departures" }
];

const destinations = [
  { name: "Racha Yai Island", desc: "Perfect for all levels, featuring stunning coral reefs, gentle drift dives, and an exciting wreck dive." },
  { name: "Racha Noi Island", desc: "Home to challenging dive sites with strong currents and dramatic drop-offs, plus easier sites like Banana Bay and Manta Bay." },
  { name: "Koh Doc Mai", desc: "A diver's paradise with vertical walls, caverns, and incredible marine life, ideal for underwater photographers." },
  { name: "Shark Point, Anemone Reef & King Cruiser Wreck", desc: "Thrill-seekers will love these iconic dive sites, offering vibrant marine biodiversity, fascinating wreck exploration, and exhilarating currents." },
  { name: "Phi Phi Islands", desc: "World-famous for crystal-clear waters, stunning coral gardens, sea turtles, and massive schools of fish." }
];

const inclusions = [
  "Hotel shuttle transfers (Patong, Kata, Karon)",
  "Full meals on board: breakfast buffet, lunch, snacks, and fresh fruits",
  "Complimentary coffee, tea, and drinking water",
  "Expert professional dive guide",
  "Full rental dive equipment, tank, and weights",
  "Comprehensive insurance (diving and accident)"
];

const itinerary = [
  { time: "08:30", activity: "Boat departure from Chalong Pier" },
  { time: "09:00", activity: "Breakfast buffet on board" },
  { time: "10:45", activity: "Dive 1" },
  { time: "12:00", activity: "Lunch and relaxation on board" },
  { time: "13:00", activity: "Dive 2" },
  { time: "14:00", activity: "Snacks and fresh fruit break" },
  { time: "15:00", activity: "Dive 3" },
  { time: "17:30 - 18:30", activity: "Return to Chalong Pier and hotel transfer" }
];
---

<Layout title="Scuba Diving Day Trips Phuket | Daily Boat Diving | Luna Diving">
  
  <div class="block w-full pt-24 md:pt-32 font-sans bg-[#fbfbfc]">
    
    <!-- Hero Section -->
    <header class="max-w-4xl mx-auto pt-12 pb-8 px-6 text-center">
      <span class="text-xs font-bold tracking-[0.25em] text-[#008EA7] uppercase block mb-3">
        Daily Scuba Diving Excursions
      </span>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-[#1A1A1A] mb-6 leading-tight">
        Unleash Your Inner Explorer <br class="hidden md:inline"/>with Phuket Diving Day Trips
      </h1>
      <p class="text-base md:text-lg text-[#50555c] leading-relaxed max-w-2xl mx-auto">
        Join us for an unforgettable daily dive adventure around Phuket's most breathtaking underwater landscapes. Whether you are a seasoned diver or a curious beginner, our expert guides will take you on an incredible journey beneath the waves.
      </p>
    </header>

    <!-- Quick Specs Grid -->
    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {quickSpecs.map((spec) => (
          <div class="bg-white border border-gray-100 p-6 rounded-[20px] shadow-sm text-center flex flex-col items-center justify-center">
            <h3 class="text-xs font-bold text-[#706F6F] uppercase tracking-wider mb-1">{spec.title}</h3>
            <p class="text-lg font-bold text-[#1A1A1A]">{spec.value}</p>
            {spec.sub && <p class="text-xs text-[#706F6F] font-normal mt-0.5">{spec.sub}</p>}
          </div>
        ))}
      </div>
    </section>

    <!-- Main Content & Details -->
    <section class="max-w-5xl mx-auto px-6 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left Column: Destinations & Itinerary -->
        <div class="lg:col-span-7 space-y-10">
          
          <!-- Destinations Overview -->
          <div class="bg-white border border-gray-200 p-8 rounded-[24px] shadow-sm">
            <h2 class="text-xl font-bold text-[#1A1A1A] mb-6">Dive Destinations</h2>
            <div class="space-y-6">
              {destinations.map((dest) => (
                <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                  <h3 class="font-bold text-base text-[#1A1A1A] mb-1.5">{dest.name}</h3>
                  <p class="text-sm text-[#50555c] leading-relaxed">{dest.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Sample Day Itinerary -->
          <div class="bg-white border border-gray-200 p-8 rounded-[24px] shadow-sm">
            <h2 class="text-xl font-bold text-[#1A1A1A] mb-2">Sample Day Itinerary</h2>
            <p class="text-xs text-[#706F6F] mb-6">Daily departures from Chalong Pier</p>
            
            <div class="relative border-l border-gray-200 ml-2 space-y-6">
              {itinerary.map((step) => (
                <div class="relative pl-6">
                  <!-- Timeline Node Dot -->
                  <span class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-[#008EA7]"></span>
                  <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                    <span class="text-sm font-bold text-[#1A1A1A] shrink-0 w-24">{step.time}</span>
                    <span class="text-sm text-[#40444b]">{step.activity}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Diving Parameters & Safety Notice -->
          <div class="bg-gray-50 border border-gray-100 p-6 rounded-[20px]">
            <h3 class="text-sm font-bold text-[#1A1A1A] uppercase tracking-wide mb-2">Diving Parameters & Safety</h3>
            <p class="text-sm text-[#50555c] leading-relaxed">
              Maximum Dive Time: 50 minutes or until the first diver reaches 50 bar / 700 psi. A mandatory 3-minute safety stop at 5 meters is strictly required for all dives to ensure optimal decompression safety.
            </p>
          </div>

        </div>

        <!-- Right Column: Pricing & Booking Card -->
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <div class="bg-[#1A1A1A] text-white p-8 rounded-[28px] shadow-lg relative overflow-hidden">
            
            <div class="absolute -right-12 -top-12 w-32 h-32 bg-[#008EA7]/20 rounded-full blur-xl"></div>
            
            <span class="text-[11px] font-bold tracking-widest text-[#008EA7] uppercase block mb-1">Daily Excursion Rates</span>
            <h3 class="text-2xl font-bold mb-6">Book Your Adventure</h3>
            
            <!-- Pricing Structure -->
            <div class="space-y-4 border-b border-white/10 pb-6 mb-6">
              <div class="flex justify-between items-baseline">
                <div>
                  <span class="block text-base font-bold text-white">Certified Diver</span>
                  <span class="text-xs text-gray-400 font-normal">Includes 3 ocean dives</span>
                </div>
                <span class="text-2xl font-extrabold text-[#008EA7]">4,900 THB</span>
              </div>
              
              <div class="flex justify-between items-baseline pt-2">
                <div>
                  <span class="block text-base font-bold text-white">Non-Diver / Free Diver</span>
                  <span class="text-xs text-gray-400 font-normal">Boat passenger access</span>
                </div>
                <span class="text-2xl font-extrabold text-gray-300">2,900 THB</span>
              </div>
            </div>

            <!-- What's Included -->
            <div class="space-y-4 mb-6">
              <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400">What's Included:</h4>
              <ul class="space-y-3 text-sm text-gray-200">
                {inclusions.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#008EA7] mt-2 shrink-0"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- What's Not Included -->
            <div class="space-y-3 mb-8 border-t border-white/10 pt-4">
              <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400">Not Included:</h4>
              <ul class="space-y-2 text-xs text-gray-300 leading-relaxed">
                <li class="flex items-start gap-2">
                  <span class="text-red-400 font-bold">-</span>
                  <span>Dive computer rental</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-400 font-bold">-</span>
                  <span>Phi Phi National Park fee (600 THB per person, paid in cash onboard)</span>
                </li>
              </ul>
            </div>

            <!-- CTA Buttons -->
            <div class="space-y-3">
              <a 
                href="https://wa.me/66918233120?text=Hi%20Luna%20Diving!%20I'm%20interested%20in%20booking%20a%20Phuket%20Scuba%20Diving%20Day%20Trip."
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center bg-[#25D366] hover:bg-[#20ba5a] text-white text-sm font-bold py-3.5 w-full rounded-full transition-all duration-300 text-center shadow-md"
              >
                Book via WhatsApp
              </a>
              <a 
                href="/contact" 
                class="flex items-center justify-center bg-white/10 hover:bg-white/20 text-white text-sm font-medium py-3.5 w-full rounded-full transition-all duration-300 text-center"
              >
                Inquire via Email
              </a>
            </div>

          </div>
        </div>

      </div>
    </section>

  </div>
</Layout>

<!-- Floating WhatsApp Button (Icona SVG tecnica mantenuta per usabilità dell'app) -->
<div class="fixed bottom-6 right-6 z-[99999] pointer-events-auto">
  <a 
    href="https://wa.me/66918233120?text=Hi%20Luna%20Diving!%20I'm%20interested%20in%20a%20Phuket%20Diving%20Day%20Trip." 
    target="_blank" 
    rel="noopener noreferrer" 
    class="flex items-center justify-center w-14 h-14 md:w-[60px] md:h-[60px] bg-[#25D366] text-white rounded-full shadow-[0_4px_16px_rgba(0,0,0,0.25)] hover:scale-105 hover:bg-[#20ba5a] transition-all duration-300 ease-out"
    aria-label="Chat on WhatsApp"
  >
    <svg class="w-7 h-7 md:w-8 md:h-8" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.454 5.709 1.455h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</div>