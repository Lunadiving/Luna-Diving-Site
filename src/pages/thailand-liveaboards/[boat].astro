---
// src/pages/thailand-liveboards/[boat].astro
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return [
    { 
      params: { boat: 'deep-andaman-queen' }, 
      props: { 
        name: 'Deep Andaman Queen',
        vesselName: 'Deep Andaman Queen',
        tagline: 'The Ultimate Steel-Hull Cruise to Richelieu Rock',
        heroImage: '/images/liveaboard/deep-andaman-queen-liveaboard.webp',
        altHero: 'Deep Andaman Queen luxury liveaboard cruising the Andaman Sea',
        description: 'The Deep Andaman Queen is a premier twin-engine steel vessel designed specifically for maximum stability and comfort in the Andaman Sea. Renowned for its exceptional space and world-class hospitality, it offers uncompromised safety and top-tier dive operations for exploring the Similan and Surin Islands national parks.',
        length: '30 m',
        guests: '22',
        speed: '12 kn',
        hull: 'Steel Hull',
        nitrox: 'Available',
        routeInfo: 'Standard dynamic routing encompassing the Similan Islands, Surin Islands, and the legendary Richelieu Rock. Marine park fees and fuel surcharges calculated strictly at booking.',
        features: ['Spacious Dive Deck', 'En-suite Cabins with AC', 'Nitrox Blending Station', 'Shaded Sundeck']
      } 
    },
    { 
      params: { boat: 'the-junk' }, 
      props: { 
        name: 'The Junk',
        vesselName: 'The Junk',
        tagline: 'Diving Heritage & Classic Wooden Sailing Charm',
        heroImage: '/images/liveaboard/the-junk-liveaboard.webp',
        altHero: 'The Junk traditional teak wood sailing vessel operating scuba diving charters',
        description: 'Step back in time aboard The Junk, a beautifully restored historical teak wood sailing vessel fully refitted with modern maritime safety and scuba diving infrastructure. Offering a completely unique atmosphere and undeniable charm, it delivers unforgettable liveaboard diving experiences with unparalleled character.',
        length: '33 m',
        guests: '18',
        speed: '9 kn',
        hull: 'Teak Wood',
        nitrox: 'Not Available',
        routeInfo: 'Heritage charter routes covering the best dive sites of the Similan national parks. Merges traditional Asian maritime history with modern western scuba safety regulations.',
        features: ['Authentic Teak Finish', 'Unique Photographic Charm', 'Fully Air-Conditioned', 'Leisure Sailing Experience']
      } 
    },
    { 
      params: { boat: 'sawasdee-fasai' }, 
      props: { 
        name: 'Sawasdee Fasai',
        vesselName: 'Sawasdee Fasai',
        tagline: 'Premium Luxury & Stabilized Deep Sea Exploration',
        heroImage: '/images/liveaboard/sawasdee-fasai-liveaboard.webp',
        altHero: 'Sawasdee Fasai premium luxury liveaboard boat anchored near Similan Islands',
        description: 'The Sawasdee Fasai is a flagship premium liveaboard engineered for exceptional deep-sea cruising. Equipped with modern marine stabilizers to guarantee a smooth journey, it caters to passionate divers who refuse to compromise on luxury, exceptional local and international cuisine, and elite comfort.',
        length: '37 m',
        guests: '30',
        speed: '11 kn',
        hull: 'Steel Hull',
        nitrox: 'Available',
        routeInfo: 'Extended itineraries covering both the Northern Similan/Surin boundaries and Southern routes like Hin Daeng, Hin Muang, and the stunning reefs of Koh Haa.',
        features: ['Marine Hull Stabilizers', 'Master & Deluxe Cabins', 'Al Fresco Dining Area', 'Large Inflatable Tenders']
      } 
    },
    { 
      params: { boat: 'pawara' }, 
      props: { 
        name: 'Pawara',
        vesselName: 'Pawara',
        tagline: 'The Ultimate Choice for Avid Divers with Free Nitrox',
        heroImage: '/images/liveaboard/pawara-liveaboard.webp',
        altHero: 'Pawara liveaboard vessel deck equipped with scuba diving gear and free nitrox tanks',
        description: 'Designed by divers, for divers, the Pawara is highly celebrated in the Phuket diving community for its optimization of space and focus on maximum bottom time. Offering Free Nitrox for all certified enriched air divers, it represents the absolute sweet spot between seasonal value and professional execution.',
        length: '35 m',
        guests: '24',
        speed: '12 kn',
        hull: 'Steel Hull',
        nitrox: 'FREE',
        routeInfo: 'Optimized cruise schedules maximizing optimal surface intervals across the best drift diving pinnacles of the Andaman Sea. Fuel and gear logistics included upfront.',
        features: ['Complimentary Nitrox', 'Dedicated Camera Tables', 'Ergonomic Dive Platform', 'Relaxed Social Vibe']
      } 
    }
  ];
}

const { boat } = Astro.params;
const { name, vesselName, tagline, heroImage, altHero, description, length, guests, speed, hull, nitrox, routeInfo, features } = Astro.props;
---

<Layout title={`${vesselName} - Pure Performance | Luna Diving`}>
  <main class="bg-[#FFFFFF] min-h-screen font-sans text-[#010205] antialiased selection:bg-[#008EA7] selection:text-white flex flex-col items-center w-full">
    
    <section class="w-full pt-20 pb-8 bg-white flex flex-col items-center text-center justify-center">
      <div class="w-full max-w-4xl px-6 flex flex-col items-center justify-center">
        <span class="text-[11px] font-bold tracking-[5px] uppercase text-gray-400 block mb-3">Luna Diving Fleet</span>
        <h1 class="text-4xl md:text-7xl font-bold tracking-tight uppercase text-[#010205] mb-6 text-center">{vesselName}</h1>
        <p class="text-sm uppercase tracking-widest text-gray-500 max-w-md border-t border-gray-100 pt-5 font-medium text-center">{tagline}</p>
      </div>
    </section>

    <section class="w-full bg-white py-12 border-b border-gray-100 flex justify-center">
      <div class="w-full max-w-5xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center md:divide-x md:divide-gray-200 items-center justify-center">
          <div class="space-y-1 flex flex-col items-center justify-center">
            <div class="text-5xl font-light tracking-tight text-[#010205]">{length}</div>
            <div class="text-[11px] uppercase tracking-[2px] font-bold text-gray-400">Length Overall</div>
          </div>
          <div class="space-y-1 flex flex-col items-center justify-center">
            <div class="text-5xl font-light tracking-tight text-[#010205]">{guests}</div>
            <div class="text-[11px] uppercase tracking-[2px] font-bold text-gray-400">Max Diver Capacity</div>
          </div>
          <div class="space-y-1 flex flex-col items-center justify-center">
            <div class="text-5xl font-light tracking-tight text-[#010205]">{speed}</div>
            <div class="text-[11px] uppercase tracking-[2px] font-bold text-gray-400">Cruising Speed</div>
          </div>
        </div>
      </div>
    </section>

    <section class="w-full max-w-6xl px-6 py-12 flex justify-center mx-auto">
      <div class="w-full overflow-hidden rounded-[2rem] bg-gray-50 aspect-[21/9]">
        <img src={heroImage} alt={altHero} class="w-full h-full object-cover" />
      </div>
    </section>

    <section class="w-full max-w-3xl px-6 py-12 flex flex-col items-center text-center space-y-8 mx-auto justify-center">
      <div class="space-y-2 flex flex-col items-center justify-center">
        <span class="text-[11px] font-bold tracking-[3px] uppercase text-gray-400 block">01 / Concept</span>
        <h2 class="text-3xl font-bold tracking-tight uppercase text-[#010205]">Vessel Profile</h2>
      </div>
      <p class="text-gray-600 text-base leading-relaxed max-w-2xl mx-auto text-center">
        {description}
      </p>
      <div class="pt-6 border-t border-gray-100 grid grid-cols-2 gap-8 w-full max-w-md mx-auto justify-center items-center">
        <div class="text-center flex flex-col items-center justify-center">
          <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 block mb-1">Hull Engineering</span>
          <span class="text-sm font-semibold text-[#010205]">{hull}</span>
        </div>
        <div class="text-center flex flex-col items-center justify-center">
          <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 block mb-1">Gas System</span>
          <span class="text-sm font-semibold text-[#008EA7]">{nitrox}</span>
        </div>
      </div>
    </section>

    <section class="bg-[#F1F1F4]/50 py-20 border-t border-b border-gray-200/30 w-full flex flex-col items-center justify-center">
      <div class="max-w-6xl w-full px-6 flex flex-col items-center justify-center">
        <div class="text-center mb-16 flex flex-col items-center justify-center">
          <span class="text-[11px] font-bold tracking-[3px] uppercase text-gray-400 block mb-2">02 / Highlights</span>
          <h3 class="text-3xl font-bold tracking-tight uppercase text-[#010205] text-center">{vesselName} Highlights</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch w-full justify-center">
          <div class="relative min-h-[380px] rounded-[2rem] overflow-hidden bg-[#010205] text-white p-8 flex flex-col justify-center items-center text-center group">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-black/60 z-10"></div>
            <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:16px_16px]"></div>
            
            <div class="relative z-20 space-y-4 max-w-xs mx-auto flex flex-col items-center justify-center">
              <h4 class="text-xl font-bold uppercase tracking-tight">Deployment & Logistics</h4>
              <p class="text-xs text-gray-300 leading-relaxed font-light text-center">{routeInfo}</p>
            </div>
          </div>

          <div class="bg-white rounded-[2rem] border border-gray-200/60 p-8 flex flex-col justify-between items-center text-center shadow-sm">
            <div class="space-y-6 w-full max-w-xs mx-auto flex flex-col items-center justify-center">
              <div class="space-y-1 flex flex-col items-center justify-center">
                <span class="text-[10px] font-bold tracking-[2px] text-gray-400 uppercase block">Specifications</span>
                <h4 class="text-xl font-bold uppercase text-[#010205]">Onboard Engineering</h4>
              </div>
              
              <ul class="divide-y divide-gray-100 border-t border-b border-gray-100 w-full">
                {features && features.map((feature) => (
                  <li class="flex items-center justify-center gap-2.5 py-3 text-xs font-semibold tracking-tight text-center">
                    <span class="text-[#010205]">{feature}</span>
                    <svg class="text-[#008EA7] flex-shrink-0" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
                    </svg>
                  </li>
                ))}
              </ul>
            </div>

            <div class="pt-6 w-full border-t border-gray-50 mt-6 flex justify-center">
              <a href="/thailand-liveboards" class="inline-flex items-center justify-center text-[10px] font-bold uppercase tracking-[2px] text-gray-400 transition-colors hover:text-[#010205] gap-2 group mx-auto">
                <svg class="flex-shrink-0 transform transition-transform group-hover:-translate-x-1" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
                </svg>
                Return to Fleet Overview
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  html, body {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 auto !important;
    padding: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: flex-start !important;
  }
  
  body > div, main {
    width: 100% !important;
    max-width: 100vw !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    margin: 0 auto !important;
  }
</style>