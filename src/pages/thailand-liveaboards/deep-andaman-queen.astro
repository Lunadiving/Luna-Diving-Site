---

<Layout title={`${vesselName} Liveaboard | Luna Diving Phuket`}>
  <main class="pcom-wrapper">
    
    <!-- SECTION 1: HERO TITLE -->
    <section class="pcom-hero">
      <span class="pcom-subtitle">M/Y {vesselName}</span>
      <h1 class="pcom-title">{vesselName}</h1>
      <div class="pcom-divider"></div>
      <p class="pcom-tagline">{tagline}</p>
    </section>

    <!-- SECTION 2: TECHNICAL SPECIFICATIONS -->
    <section class="pcom-specs-container">
      <div class="pcom-specs-grid">
        {technicalSpecs.map((spec) => (
          <div class="spec-item">
            <span class="spec-label">{spec.label}</span>
            <span class="spec-value">{spec.value}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- SECTION 3: PREMIUM IMAGES CAROUSEL -->
    <section class="pcom-gallery-section">
      <div class="gallery-slider-outer">
        <div id="slider" class="gallery-slider-inner no-scrollbar">
          {slideshow.map((slide, index) => (
            <div class="gallery-slide">
              <img 
                src={slide.img} 
                alt={`${vesselName} - ${slide.text}`} 
                loading={index === 0 ? "eager" : "lazy"}
                decoding={index === 0 ? "sync" : "async"}
              />
              <div class="gallery-caption">
                <span class="caption-count">Vessel Tour {index + 1} / {slideshow.length}</span>
                <p class="caption-text">{slide.text}</p>
              </div>
            </div>
          ))}
        </div>

        <button id="prevBtn" class="nav-button prev" aria-label="Previous">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg>
        </button>
        <button id="nextBtn" class="nav-button next" aria-label="Next">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg>
        </button>
      </div>
    </section>

    <!-- SECTION 4: CABIN PRICING MATRIX -->
    <section class="pcom-pricing-section">
      <div class="pricing-header">
        <h2 class="content-heading">Cabin Options & Rates</h2>
        <div class="heading-line"></div>
      </div>
      
      <div class="pcom-cabins-list">
        {cabins.map((cabin) => (
          <div class="cabin-rate-card">
            <div class="cabin-main-info">
              <h3 class="cabin-name">{cabin.name}</h3>
              <span class="cabin-location">{cabin.location}</span>
              <p class="cabin-details">{cabin.details}</p>
              <span class="cabin-trip-tag">{cabin.trip}</span>
            </div>
            <div class="cabin-price-zone">
              <span class="price-amount">{cabin.price}</span>
              <span class="price-label">Per Person</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SECTION 5: INCLUSIONS & FEES -->
    <section class="pcom-details-grid-section">
      <div class="details-split-container">
        <div class="details-column included-box">
          <h3 class="details-col-title">
            <svg class="title-icon icon-inc" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Included In The Price
          </h3>
          <ul class="details-list">
            {includedItems.map((item) => (
              <li class="details-item">
                <svg class="item-dot dot-inc" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="details-column excluded-box">
          <h3 class="details-col-title">
            <svg class="title-icon icon-exc" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Not Included / Extra Fees
          </h3>
          <ul class="details-list">
            {notIncludedItems.map((item) => (
              <li class="details-item exc-item">
                <svg class="item-dot dot-exc" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
                <div class="exc-text-wrapper">
                  <span class="exc-main-text">{item.text}</span>
                  {item.highlight && <span class="exc-highlight">{item.highlight}</span>}
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- SECTION 6: SCHEDULE & DEPARTURES TABLE -->
    <section class="pcom-schedule-section">
      <div class="pricing-header">
        <h2 class="content-heading">Cruise Schedule & Availability</h2>
        <div class="heading-line"></div>
      </div>

      <div class="table-responsive-container">
        <table class="schedule-table">
          <thead>
            <tr>
              <th>Departure Dates</th>
              <th>Itinerary</th>
              <th>Start / Finish Port</th>
              <th class="table-action-header">Action</th>
            </tr>
          </thead>
          <tbody>
            {schedule.map((row) => (
              <tr>
                <td class="td-dates">{row.dates}</td>
                <td class="td-itinerary">
                  <span class="itinerary-text">{row.itinerary}</span>
                  <span class={`type-badge badge-${row.type.toLowerCase().replace(' ', '-')}`}>
                    {row.type}
                  </span>
                </td>
                <td class="td-route">{row.route}</td>
                <td class="td-action">
                  <a href={`/contact?vessel=${vesselName}&date=${encodeURIComponent(row.dates)}`} class="table-book-btn">
                    Book
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ✍️ SEZIONE 7: VESSEL PROFILE CON PAROLE CHIAVE SEO OTTIMIZZATE -->
    <section class="pcom-content-grid">
      <div class="content-main">
        <h2 class="content-heading">Vessel Profile</h2>
        <div class="heading-line"></div>
        <p class="paragraph">
          The <strong>Deep Andaman Queen</strong> is an exceptional liveaboard cruise boat designed for passionate divers looking to explore the premier dive sites along Thailand's magnificent west coast [cite: Giorgio is a professional web developer and SEO specialist based in Phuket, Thailand. The user manages the website luna-diving-thailand.com and frequently requests SEO audits, technical optimizations, and content translations for business operations located in Phuket and Khao Lak. The user is deeply involved in the scuba diving industry, specifically focusing on liveaboard cruises and day trips in the Andaman Sea. Sustained engagement in optimizing content for Similan Islands, Richelieu Rock, and Phi Phi Islands diving excursions.]. Hosting a maximum of <strong>25 guests across 11 finely appointed cabins</strong>, it offers a remarkably intimate and highly personalized experience. This robust vessel provides unforgettable dive cruises navigating the crystal-clear waters of the <strong>Similan Islands, Surin Islands, Richelieu Rock</strong>, and the pristine, remote waters of the <strong>Mergui Archipelago in Myanmar (Burma)</strong>.
        </p>
        <p class="paragraph">
          Life on board balances high-end comfort with pure adventure. The ship's culinary team consists of **skilled cooks renowned across Phuket Island**, dedicated to preparing an exceptional variety of traditional Thai dishes and international cuisine. Between dives, guests can relax in a beautiful, fully air-conditioned saloon equipped with panoramic windows, an entertainment center, and a curated library of marine biology books and diving magazines. For sun worshippers, the expansive top deck features plush sun loungers and sofas perfect for tracking ocean sunsets.
        </p>
        <p class="paragraph">
          Diving operations are meticulously organized on the massive **two-level diving platform**. Its generous size and smart, split-level engineering make entries and exits effortless for all divers, avoiding any bottlenecking during pre-dive prep. Combining robust safety, specialized dive infrastructure, and top-tier hospitality, the Deep Andaman Queen stands as an excellent choice for a premier liveaboard experience in Southeast Asia.
        </p>
      </div>

      <div class="content-sidebar">
        <div class="booking-sticky-box">
          <h3 class="sidebar-heading">Ready to Dive?</h3>
          <p class="sidebar-text">Plan your trip aboard the Deep Andaman Queen. Slots fill up quickly during the peak diving season.</p>
          <a href="/contact" class="pcom-btn-primary">
            Inquire This Liveaboard
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  const slider = document.getElementById('slider') as HTMLDivElement | null;
  const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement | null;

  if (slider && prevBtn && nextBtn) {
    nextBtn.addEventListener('click', (): void => {
      const slideWidth = slider.clientWidth;
      if (slider.scrollLeft + slideWidth >= slider.scrollWidth - 5) {
        slider.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        slider.scrollBy({ left: slideWidth, behavior: 'smooth' });
      }
    });

    prevBtn.addEventListener('click', (): void => {
      const slideWidth = slider.clientWidth;
      if (slider.scrollLeft <= 0) {
        slider.scrollTo({ left: slider.scrollWidth, behavior: 'smooth' });
      } else {
        slider.scrollBy({ left: -slideWidth, behavior: 'smooth' });
      }
    });
  }
</script>

<style>
  :root {
    --pcom-font: "Porsche Next", "Arial Narrow", Arial, sans-serif;
    --pcom-color-canvas: #fff;
    --pcom-color-primary: #010205;
    --pcom-color-surface: #f1f1f4;
    --pcom-color-accent: #008EA7;
    --pcom-color-danger: #b31010;
    --pcom-color-text-muted: #4f5059;
    
    --pcom-space-md: clamp(16px, 1.25vw + 12px, 36px);
    --pcom-space-lg: clamp(32px, 2.75vw + 23px, 76px);
  }

  .pcom-wrapper {
    background-color: var(--pcom-color-canvas);
    min-height: 100vh;
    font-family: var(--pcom-font);
    color: var(--pcom-color-primary);
    width: 100%;
    box-sizing: border-box;
    padding-top: clamp(100px, 10vw, 140px);
    display: flex;
    flex-direction: column;
    align-items: center;
    -webkit-font-smoothing: antialiased;
  }

  /* Hero */
  .pcom-hero {
    width: 100%;
    max-width: 820px;
    padding: 0 var(--pcom-space-md);
    text-align: center;
    margin-bottom: var(--pcom-space-md);
  }

  .pcom-subtitle {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--pcom-color-accent);
    display: block;
    margin-bottom: 12px;
  }

  .pcom-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0 0 16px 0;
    line-height: 1.1;
  }

  .pcom-divider {
    width: 60px;
    height: 2px;
    background-color: var(--pcom-color-primary);
    margin: 0 auto 16px auto;
  }

  .pcom-tagline {
    font-size: clamp(11px, 1.5vw, 13px);
    color: var(--pcom-color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
  }

  /* Specs */
  .pcom-specs-container {
    width: 100%;
    background-color: #fafafa;
    border-top: 1px solid var(--pcom-color-surface);
    border-bottom: 1px solid var(--pcom-color-surface);
    padding: 24px 0;
    margin-bottom: var(--pcom-space-lg);
  }

  .pcom-specs-grid {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 var(--pcom-space-md);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 768px) {
    .pcom-specs-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .spec-item:not(:first-child) {
      border-left: 1px solid #e5e7eb;
      padding-left: 20px;
    }
  }

  .spec-item {
    text-align: center;
  }

  .spec-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--pcom-color-text-muted);
    font-weight: 700;
    display: block;
    margin-bottom: 4px;
  }

  .spec-value {
    font-size: clamp(15px, 2vw, 18px);
    font-weight: 700;
  }

  /* Gallery */
  .pcom-gallery-section {
    width: 100%;
    max-width: 820px;
    padding: 0 var(--pcom-space-md);
    margin-bottom: var(--pcom-space-lg);
    box-sizing: border-box;
    position: relative;
  }

  .gallery-slider-outer {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .gallery-slider-inner {
    width: 100%;
    display: flex;
    overflow-x: auto;
    snap-type: x mandatory;
    scroll-behavior: smooth;
    border-radius: 8px;
    background-color: var(--pcom-color-primary);
    height: 240px !important;
  }

  @media (min-width: 768px) {
    .gallery-slider-inner {
      height: 400px !important;
    }
  }

  .gallery-slide {
    width: 100% !important;
    flex-shrink: 0;
    height: 100% !important;
    position: relative;
    snap-align: start;
  }

  .gallery-slide img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
