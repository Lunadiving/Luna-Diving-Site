---
// Import the global Tailwind stylesheet (assicurati che il percorso sia corretto)
import '../../styles/global.css';

const fleet = [
  {
    slug: "deep-andaman-queen",
    name: "Deep Andaman Queen",
    image: "/images/liveaboard/deep-andaman-queen-liveaboard.webp",
    altText: "Deep Andaman Queen liveaboard scuba diving boat cruising in the Andaman Sea, Thailand", 
    tags: ["Standard Route", "Steel Hull", "Nitrox Available"],
    specs: [
      { val: "22-Guest", desc: "Maximum Capacity, 11 Twin/Double Cabins" },
      { val: "30 Meters", desc: "Overall Length (LOA)" },
      { val: "12 Knots", desc: "Cruising Speed (Twin Engines)" }
    ],
    legal: "Fuel consumption and marine park fees calculated separately. Route includes Similan Islands, Surin Islands, and Richelieu Rock."
  },
  {
    slug: "the-junk",
    name: "The Junk",
    image: "/images/liveaboard/the-junk-liveaboard.webp",
    altText: "The Junk traditional teak wood sailing vessel operating scuba diving charters",
    tags: ["Classic Teak", "Historical", "Nitrox Available"],
    specs: [
      { val: "18-Guest", desc: "Maximum Capacity, Traditional Style" },
      { val: "33 Meters", desc: "Overall Length (LOA)" },
      { val: "9 Knots", desc: "Cruising Speed under Sail" }
    ],
    legal: "Heritage vessel fully refitted for modern scuba safety and comfort. Unique charm and traditional atmosphere."
  },
  {
    slug: "sawasdee-fasai",
    name: "Sawasdee Fasai",
    image: "/images/liveaboard/sawasdee-fasai-liveaboard.webp",
    altText: "Sawasdee Fasai luxury liveaboard diving boat at Similan Islands national park", 
    tags: ["Premium Fleet", "Stabilized", "Nitrox Available"],
    specs: [
      { val: "30-Guest", desc: "Maximum Capacity, Premium Comfort" },
      { val: "37 Meters", desc: "Overall Length (LOA)" },
      { val: "11 Knots", desc: "Cruising Speed" }
    ],
    legal: "Exploring Similan Islands, Koh Bon, and Koh Tachai. Exceptional local and international cuisine served daily."
  },
  {
    slug: "pawara",
    name: "Pawara",
    image: "/images/liveaboard/pawara-liveaboard.webp",
    altText: "Pawara luxury liveaboard scuba diving boat in the Andaman Sea, Thailand",
    tags: ["Budget Friendly", "Free Nitrox", "Nitrox Available"],
    specs: [
      { val: "24-Guest", desc: "Maximum Capacity, 12 Cabins" },
      { val: "35 Meters", desc: "Overall Length (LOA)" },
      { val: "12 Knots", desc: "Cruising Speed" }
    ],
    legal: "Free Nitrox for certified divers. Designed specifically for maximum bottom time and optimal surface intervals."
  }
];
---


<header class="max-w-5xl mx-auto pt-16 px-6 text-center">
  <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-[#1A1A1A] mb-12">
    Thailand Liveaboard Fleet
  </h1>
</header>

<main class="max-w-5xl mx-auto px-6 pb-16">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-12">    {fleet.map((boat) => (
      <article class="group relative flex flex-col justify-between bg-white border border-gray-200 p-6 rounded-[24px] shadow-sm transition-all duration-300 hover:shadow-md">
        
        <div>
          <div class="w-full aspect-video bg-[#f8f8fa] overflow-hidden relative rounded-xl mb-6">              
            <img 
              src={boat.image} 
              alt={boat.altText || boat.name} 
              class="w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
            <a href={`/thailand-liveaboards/${boat.slug}`} class="absolute inset-0 z-10" aria-label={`Explore ${boat.name} in detail`}></a>
          </div>

          <div class="space-y-3">
            <h3 class="text-xl font-bold tracking-tight text-[#1A1A1A] transition-colors group-hover:text-[#008EA7]">
              {boat.name}
            </h3>
            
            <div class="flex flex-wrap gap-2">
              {boat.tags.map((tag) => (
                <span class="bg-[#008EA7]/10 text-[#008EA7] text-xs font-medium px-3 py-1 rounded-md border border-[#008EA7]/20">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <ul class="grid grid-cols-3 gap-4 my-6 py-4 border-t border-b border-gray-100" aria-label="Technical highlights">
            {boat.specs.map((spec) => (
              <li class="space-y-1">
                <div class="text-base font-semibold text-[#1A1A1A] tracking-tight leading-none">
                  {spec.val}
                </div>
                <div class="text-[11px] text-[#706F6F] font-normal leading-tight">
                  {spec.desc}
                </div>
              </li>
            ))}
          </ul>

          <div class="mb-6">
            <p class="text-[12px] text-[#706F6F] font-normal leading-relaxed">
              {boat.legal}
            </p>
          </div>
        </div>

        <div class="mt-auto pt-2 z-20">
          <a 
            href={`/thailand-liveaboards/${boat.slug}`} 
            class="flex items-center justify-center bg-[#1A1A1A] text-white text-xs font-medium py-3 w-full rounded-full hover:bg-[#008EA7] transition-colors duration-300 text-center"
          >
            Explore in Detail
          </a>
        </div>

      </article>
    ))}
  </div>
</main>