---
// src/pages/thailand-liveaboard/fleet/[boat].astro
import Layout from '../../../layouts/Layout.astro'; // 🚀 Corretto a 3 passaggi indietro per la tua struttura

// 1. Dynamic Routing Setup with updated image paths inside images/liveaboard/fleet/
export async function getStaticPaths() {
  return [
    { 
      params: { boat: 'mv-deep-andaman-queen' }, 
      props: { 
        name: 'MV Deep Andaman Queen',
        tagline: 'The Ultimate Steel-Hull Cruise to Richelieu Rock',
        heroImage: '/images/liveaboard/fleet/mv-deep-andaman-queen.webp', // 🚀 Percorso aggiornato
        altHero: 'MV Deep Andaman Queen luxury liveaboard cruising the Andaman Sea in Thailand',
        description: 'The MV Deep Andaman Queen is a premier twin-engine steel vessel designed specifically for maximum stability and comfort in the Andaman Sea. Renowned for its exceptional space and world-class hospitality, it offers uncompromised safety and top-tier dive operations for exploring the Similan and Surin Islands national parks.',
        length: '30 Meters',
        guests: '22 Guests',
        speed: '12 Knots',
        hull: 'Steel Hull',
        nitrox: 'Available',
        routeInfo: 'Standard dynamic routing encompassing the Similan Islands, Surin Islands, and the legendary Richelieu Rock. Marine park fees and fuel surcharges calculated strictly at booking.',
        features: ['Spacious Dive Deck', 'En-suite Cabins with AC', 'Nitrox Blending Station', 'Shaded Sundeck']
      } 
    },
    { 
      params: { boat: 'the-junk' }, 
      props: { 
        name: 'The Junk',
        tagline: 'Diving Heritage & Classic Wooden Sailing Charm',
        heroImage: '/images/liveaboard/fleet/the-junk.webp', // 🚀 Percorso aggiornato
        altHero: 'The Junk traditional teak wood sailing vessel operating scuba diving charters in Thailand',
        description: 'Step back in time aboard The Junk, a beautifully restored historical teak wood sailing vessel fully refitted with modern maritime safety and scuba diving infrastructure. Offering a completely unique atmosphere and undeniable charm, it delivers unforgettable liveaboard diving experiences with unparalleled character.',
        length: '33 Meters',
        guests: '18 Guests',
        speed: '9 Knots',
        hull: 'Teak Wood',
        nitrox: 'Not Available',
        routeInfo: 'Heritage charter routes covering the best dive sites of the Similan national parks. Merges traditional Asian maritime history with modern western scuba safety regulations.',
        features: ['Authentic Teak Finish', 'Unique Photographic Charm', 'Fully Air-Conditioned', 'Leisure Sailing Experience']
      } 
    },
    { 
      params: { boat: 'mv-sawasdee-fasai' }, 
      props: { 
        name: 'MV Sawasdee Fasai',
        tagline: 'Premium Luxury & Stabilized Deep Sea Exploration',
        heroImage: '/images/liveaboard/fleet/mv-sawasdee-fasai.webp', // 🚀 Percorso aggiornato
        altHero: 'MV Sawasdee Fasai premium luxury liveaboard boat anchored near Similan Islands',
        description: 'The MV Sawasdee Fasai is a flagship premium liveaboard engineered for exceptional deep-sea cruising. Equipped with modern marine stabilizers to guarantee a smooth journey, it caters to passionate divers who refuse to compromise on luxury, exceptional local and international cuisine, and elite comfort.',
        length: '37 Meters',
        guests: '30 Guests',
        speed: '11 Knots',
        hull: 'Steel Hull',
        nitrox: 'Available',
        routeInfo: 'Extended itineraries covering both the Northern Similan/Surin boundaries and Southern routes like Hin Daeng, Hin Muang, and the stunning reefs of Koh Haa.',
        features: ['Marine Hull Stabilizers', 'Master & Deluxe Cabins', 'Al Fresco Dining Area', 'Large Inflatable Tenders']
      } 
    },
    { 
      params: { boat: 'mv-pawara' }, 
      props: { 
        name: 'MV Pawara',
        tagline: 'The Ultimate Choice for Avid Divers with Free Nitrox',
        heroImage: '/images/liveaboard/fleet/mv-pawara.webp', // 🚀 Percorso aggiornato
        altHero: 'MV Pawara liveaboard vessel deck equipped with scuba diving gear and free nitrox tanks',
        description: 'Designed by divers, for divers, the MV Pawara is highly celebrated in the Phuket diving community for its optimization of space and focus on maximum bottom time. Offering Free Nitrox for all certified enriched air divers, it represents the absolute sweet spot between seasonal value and professional execution.',
        length: '35 Meters',
        guests: '24 Guests',
        speed: '12 Knots',
        hull: 'Steel Hull',
        nitrox: 'FREE for Certified Divers',
        routeInfo: 'Optimized cruise schedules maximizing optimal surface intervals across the best drift diving pinnacles of the Andaman Sea. Fuel and gear logistics included upfront.',
        features: ['Complimentary Nitrox', 'Dedicated Camera Tables', 'Ergonomic Dive Platform', 'Relaxed Social Vibe']
      } 
    }
  ];
}

const { boat } = Astro.params;
const { name, tagline, heroImage, altHero, description, length, guests, speed, hull, nitrox, routeInfo, features } = Astro.props;
---

<Layout title={`${name} - Liveaboard Thailand | Luna Diving`}>
  <main class="bg-white min-h-screen font-sans text-[#1A1A1A]">
    
    <section class="relative w-full h-[65vh] overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 z-10 bg-gradient-to-t from-black/80 via-black/30 to-black/20"></div>
      <img 
        src={heroImage} 
        alt={altHero} 
        class="absolute top-0 left-0 w-full h-full object-cover z-0"
      />
      <div class="relative z-20 text-center px-6 max-w-4xl text-white space-y-3">
        <span class="text-xs font-bold tracking-[3px] uppercase text-[#008EA7] bg-[#008EA7]/10 border border-[#008EA7]/30 px-4 py-1.5 rounded-full backdrop-blur-sm">Our Fleet</span>
        <h1 class="text-3xl md:text-5xl font-black tracking-tight text-white uppercase">{name}</h1>
        <p class="text-sm md:text-lg font-light text-gray-200 tracking-wide">{tagline}</p>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-gray-50/50 py-6">
      <div class="max-w-5xl mx-auto px-6">
        <ul class="grid grid-cols-2 md:grid-cols-5 gap-y-4 gap-x-2 text-center" aria-label="Technical Highlights">
          <li class="space-y-1 border-r border-gray-200/60 last:border-0">
            <div class="text-[10px] uppercase tracking-wider font-semibold text-gray-400">Length</div>
            <div class="text-base font-bold text-[#1A1A1A]">{length}</div>
          </li>
          <li class="space-y-1 md:border-r border-gray-200/60 last:border-0">
            <div class="text-[10px] uppercase tracking-wider font-semibold text-gray-400">Capacity</div>
            <div class="text-base font-bold text-[#1A1A1A]">{guests}</div>
          </li>
          <li class="space-y-1 border-r border-gray-200/60 last:border-0">
            <div class="text-[10px] uppercase tracking-wider font-semibold text-gray-400">Speed</div>
            <div class="text-base font-bold text-[#1A1A1A]">{speed}</div>
          </li>
          <li class="space-y-1 md:border-r border-gray-200/60 last:border-0">
            <div class="text-[10px] uppercase tracking-wider font-semibold text-gray-400">Build</div>
            <div class="text-base font-bold text-[#1A1A1A]">{hull}</div>
          </li>
          <li class="space-y-1 col-span-2 md:col-span-1">
            <div class="text-[10px] uppercase tracking-wider font-semibold text-gray-400">Nitrox</div>
            <div class="text-base font-bold text-[#008EA7]">{nitrox}</div>
          </li>
        </ul>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="md:col-span-2 space-y-6">
        <h2 class="text-2xl font-bold tracking-tight">Vessel Overview</h2>
        <p class="text-base text-gray-600 leading-relaxed font-normal">
          {description}
        </p>
        <div class="p-5 bg-gray-50 border border-gray-100 rounded-2xl text-xs text-gray-500 leading-relaxed">
          <strong class="text-gray-700 block mb-1">Route & Terms Information:</strong>
          {routeInfo}
        </div>
      </div>

      <div class="bg-white border border-gray-200/80 p-6 rounded-2xl h-fit shadow-sm space-y-4">
        <h3 class="text-lg font-bold tracking-tight">Key Features</h3>
        <ul class="space-y-2.5">
          {features.map((feature) => (
            <li class="flex items-center text-sm text-gray-600 font-medium gap-3">
              <svg class="w-4 h-4 text-[#008EA7] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 pb-24 space-y-6">
      <div class="border-t border-gray-100 pt-12">
        <h2 class="text-2xl font-bold tracking-tight mb-2">Upcoming Cruise Schedules</h2>
        <p class="text-sm text-gray-500 max-w-2xl mb-6">Select your dates to book your liveaboard safari. Availability is updated dynamically.</p>
        
        <div class="bg-gray-50 border-2 border-dashed border-gray-200 rounded-2xl p-12 text-center text-sm text-gray-400 font-medium">
          📅 Cruise Schedule & Live Date Search Engine Coming Soon
        </div>
      </div>
    </section>

  </main>
</Layout>