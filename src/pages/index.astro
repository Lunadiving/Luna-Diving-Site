---
import Layout from '../layouts/Layout.astro';

// Structural mapping of your 6 main grid blocks for SEO optimization
const mainCategories = [
  {
    name: 'Liveaboard',
    seoTitle: 'Liveaboard Cruises',
    description: 'Multi-day diving safaris to the Similan Islands and Richelieu Rock.',
    image: '/hero-poster.webp',
    link: '/liveboards',
    altText: 'Premium liveaboard diving boat navigating the Andaman Sea in Thailand'
  },
  {
    name: 'Yacht',
    seoTitle: 'Yacht Charter',
    description: 'Private luxury catamaran and yacht rentals for custom cruise itineraries.',
    image: '/hero-poster.webp',
    link: '/yacht-charter',
    altText: 'Luxury private yacht charter anchored near a tropical island in Thailand'
  },
  {
    name: 'Courses',
    seoTitle: 'Scuba Diving Courses',
    description: 'PADI & SSI certifications from Open Water to professional divemaster levels.',
    image: '/hero-poster.webp',
    link: '/diving-courses',
    altText: 'Scuba diving instructor teaching students open water skills in clear water'
  },
  {
    name: 'Day Trip',
    seoTitle: 'Daily Dive Trips',
    description: 'Daily diving excursions to local reefs, Phi Phi Islands, and Racha Islands.',
    image: '/hero-poster.webp',
    link: '/day-trips',
    altText: 'Speedboat carrying scuba divers to local day trip dive sites'
  },
  {
    name: 'Itinerary',
    seoTitle: 'Cruise Itineraries',
    description: 'Detailed schedules and dynamic routing maps for our upcoming dive seasons.',
    image: '/hero-poster.webp',
    link: '/itineraries',
    altText: 'Top view map overlay showing sailing routes across the Andaman Sea islands'
  },
  {
    name: 'Dive Sites',
    seoTitle: 'Andaman Dive Sites',
    description: 'Explore deep-sea marine life profiles of Richelieu Rock and national parks.',
    image: '/hero-poster.webp',
    link: '/dive-sites',
    altText: 'Vibrant coral reef teeming with colorful marine life at Richelieu Rock Thailand'
  },
];
---

<Layout title="Luna Diving | Premium Thailand Liveboards & Scuba Adventures">
  <main class="main-wrapper" id="theme-wrapper">
    
    <section class="hero-container">
      <video autoplay muted loop playsinline poster="/hero-poster.webp" class="video-background">
        <source src="/hero-background.mp4" type="video/mp4" />
      </video>
      <div class="video-overlay"></div>
      <div class="hero-content">
        <img src="/logo-luna.webp" alt="Luna Diving Official Logo" class="hero-logo animated-element fade-in-first" />
        <h1 class="hero-title animated-element fade-in-second">EXPERIENCE THE DEPTHS</h1>
        <p class="hero-subtitle animated-element fade-in-third">Premium Liveaboard & Diving Cruises in the Andaman Sea</p>
        <button class="hero-cta-button animated-element fade-in-fourth" onclick="document.getElementById('dark-fleet-section').scrollIntoView({behavior: 'smooth'})">Explore Categories</button>
      </div>
    </section>

    <section class="adventure-starts">
      <h2>Your Andaman Sea Adventure Starts Here.</h2>
    </section>

    <section class="liveaboard-fleet" id="dark-fleet-section">
      <div class="card-grid">
        {mainCategories.map((category) => (
          <div class="liveaboard-card">
            <div class="card-image-wrapper">
              <img src={category.image} alt={category.altText} class="card-image" />
              <div class="card-gradient"></div>
            </div>
            <div class="card-content">
              {/* Elegant cursive identifier at the top */}
              <span class="card-name-cursive">{category.name}</span>
              
              <div class="card-text-bottom">
                <h3 class="card-name-bold">{category.seoTitle}</h3>
                <p class="card-description">{category.description}</p>
                <a href={category.link} class="card-cta">
                  <span>View Details</span>
                  <svg class="luna-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="last-minute-banner">
        <div class="banner-overlay"></div>
        <div class="banner-content">
          <span class="banner-tag">Limited Availability</span>
          <h2>Last Minute Deals & Liveaboard Offers</h2>
          <p>Grab exclusive empty-cabin discounts and last-second seasonal promotions for upcoming trips.</p>
          <a href="/last-minute" class="banner-btn">Check Live Deals</a>
        </div>
      </div>
    </section>

    <style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,400;1,600&display=swap');

  .main-wrapper {
    margin: 0;
    padding: 0;
    background-color: #ffffff;
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #000000;
    transition: background-color 0.8s cubic-bezier(0.25, 1, 0.5, 1), color 0.8s ease;
  }

  .main-wrapper.is-dark {
    background-color: #000000;
    color: #ffffff;
  }

  /* HERO STYLING */
  .hero-container {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .video-background {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    z-index: 1;
    transform: translate(-50%, -50%);
    object-fit: cover;
  }

  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.12);
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    padding: 0 1.5rem;
  }

  .hero-logo {
    width: 160px;
    height: auto;
    margin-bottom: 2.5rem;
    filter: drop-shadow(0 2px 8px rgba(255, 255, 255, 0.8)); 
  }

  .hero-title {
    color: #000000;
    font-size: clamp(2.2rem, 6vw, 4.5rem); 
    font-weight: 900;
    letter-spacing: 5px; 
    margin: 0 0 1rem 0;
    text-transform: uppercase;
  }

  .hero-subtitle {
    color: #1c1c1e;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 400;
    letter-spacing: 2px;
    margin-bottom: 3.5rem;
  }

  .hero-cta-button {
    background-color: #000000;
    border: 1px solid #000000;
    color: #ffffff;
    padding: 1.2rem 3rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-cta-button:hover {
    background-color: #ffffff;
    color: #000000;
  }

  .adventure-starts {
    text-align: center;
    padding: 7rem 2rem 4rem 2rem;
  }

  .adventure-starts h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    letter-spacing: -0.5px;
    margin: 0;
    transition: color 0.5s ease;
  }
  .main-wrapper.is-dark .adventure-starts h2 { color: #ffffff; }

  /* FLEET CONTAINER & GRID */
  .liveaboard-fleet {
    padding: 0 4rem 8rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 1100px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 700px) {
    .card-grid { grid-template-columns: 1fr; }
    .liveaboard-fleet { padding: 0 1.5rem 4rem 1.5rem; }
  }

  /* CATEGORY CARD SQUARE IDENTITY */
  .liveaboard-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background-color: #121212;
    aspect-ratio: 1.1 / 1;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  .card-image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .liveaboard-card:hover .card-image { transform: scale(1.04); }

  .card-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0.85) 90%);
    z-index: 2;
  }

  .card-content {
    position: relative;
    z-index: 3;
    padding: 2.2rem;
    color: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    box-sizing: border-box;
  }

  .card-name-cursive {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.8rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .card-text-bottom { display: flex; flex-direction: column; }
  .card-name-bold { font-size: 1.4rem; font-weight: 700; margin: 0 0 0.4rem 0; letter-spacing: -0.2px; }
  .card-description { font-size: 0.85rem; color: #aaaaaa; margin: 0 0 1.5rem 0; line-height: 1.4; }
  
  .card-cta {
    display: inline-flex;
    align-items: center;
    color: #ffffff !important;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    gap: 0.5rem;
  }

  .luna-arrow {
    width: 16px !important;
    height: 16px !important;
    color: #ffffff !important;
    transition: transform 0.3s ease;
  }
  .card-cta:hover .luna-arrow { transform: translateX(5px); }

  /* --- 4. LAST MINUTE HORIZONTAL BANNER --- */
  .last-minute-banner {
    position: relative;
    width: 100%;
    background-color: #0c0c0e;
    border: 1px solid #1c1c1e;
    border-radius: 20px;
    overflow: hidden;
    padding: 4rem;
    box-sizing: border-box;
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
  }

  /* Fixed background syntax error here */
  .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(90deg, rgba(0,0,0,0.85) 40%, rgba(0,0,0,0.1) 100%), url('/hero-poster.webp');
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  .banner-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    color: #ffffff;
  }

  .banner-tag {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ff453a; 
    font-weight: 700;
    display: block;
    margin-bottom: 0.5rem;
  }

  .banner-content h2 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.8rem 0;
    letter-spacing: -0.5px;
  }

  .banner-content p {
    font-size: 0.95rem;
    color: #aaaaaa;
    line-height: 1.5;
    margin: 0 0 2rem 0;
  }

  .banner-btn {
    background-color: #ffffff;
    color: #000000;
    text-decoration: none;
    padding: 0.9rem 2.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 6px;
    display: inline-block;
    transition: background-color 0.3s;
  }
  .banner-btn:hover { background-color: #cccccc; }

  @media (max-width: 700px) {
    .last-minute-banner { padding: 2.5rem; }
    .banner-overlay { background-image: linear-gradient(180deg, rgba(0,0,0,0.9) 100%, rgba(0,0,0,0.5) 100%); }
  }

  /* EXIT SECTION */
  .next-section-placeholder {
    text-align: center;
    padding: 12rem 2rem;
  }

  .next-section-placeholder h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    transition: color 0.5s ease;
  }

  .next-section-placeholder p {
    font-size: 1.1rem;
    color: #666666;
    max-width: 600px;
    margin: 0 auto;
    transition: color 0.5s ease;
  }
  .main-wrapper.is-dark .next-section-placeholder p { color: #aaaaaa; }

  .animated-element {
    opacity: 0;
    transform: translateY(20px);
    animation: lunaFadeIn 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  .fade-in-first { animation-delay: 200ms; }
  .fade-in-second { animation-delay: 500ms; }
  .fade-in-third { animation-delay: 800ms; }
  .fade-in-fourth { animation-delay: 1100ms; }

  @keyframes lunaFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>